# ══════════════════════════════════════════════════════════
# FORGE — Environment Configuration
# Copy to .env and fill in real values. NEVER commit .env
# ══════════════════════════════════════════════════════════

# ── FORGE SERVER ─────────────────────────────────────────
FORGE_SECRET=your-webhook-secret-here
FORGE_MEDIA_DIR=/opt/forge/media
FORGE_SOULS_DIR=/opt/forge/souls
FORGE_PORT=5000

# ── AI / SCRIPT GENERATION ───────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-7

# ── VOICE (choose one provider) ──────────────────────────
VOICE_PROVIDER=elevenlabs       # elevenlabs | kokoro
ELEVENLABS_API_KEY=...
# Voice IDs — one per persona (get from ElevenLabs dashboard)
ELEVENLABS_VOICE_ID_DEFAULT=...
# Optional: per-persona overrides (uses DEFAULT if not set)
# ELEVENLABS_VOICE_ID_PERSONA_NAME=...

# Local Kokoro (if VOICE_PROVIDER=kokoro)
KOKORO_HOST=http://localhost:8880
KOKORO_VOICE=af_heart            # see Kokoro voice list

# ── AVATAR VIDEO (choose one provider) ───────────────────
VISUAL_PROVIDER=heygen           # heygen | liveportrait | did
HEYGEN_API_KEY=...
# Avatar IDs — one per persona (get from HeyGen dashboard)
HEYGEN_AVATAR_ID_DEFAULT=...
# Optional: per-persona overrides
# HEYGEN_AVATAR_ID_PERSONA_NAME=...

# D-ID fallback
DID_API_KEY=...

# Local LivePortrait (if VISUAL_PROVIDER=liveportrait)
LIVEPORTRAIT_HOST=http://localhost:7860

# ── YOUTUBE ──────────────────────────────────────────────
# OAuth credentials from Google Cloud Console
YOUTUBE_CLIENT_ID=...
YOUTUBE_CLIENT_SECRET=...
# Token file path (generated on first auth)
YOUTUBE_TOKEN_PATH=/opt/forge/creds/youtube_token.json

# ── NOTION ───────────────────────────────────────────────
NOTION_API_KEY=secret_...
# Database IDs (get from Notion URL)
NOTION_VIDEO_REGISTRY_DB=...      # main video tracking database
NOTION_CONTENT_CALENDAR_DB=...    # content calendar

# ── CEREBRO (notification target) ────────────────────────
CEREBRO_WEBHOOK_URL=https://n8n.digitalmonkey.io/webhook/cerebro-notify
CEREBRO_SLACK_CHANNEL=#forge-ops

# ── RESEARCH / SCOUT ─────────────────────────────────────
REDDIT_CLIENT_ID=...
REDDIT_CLIENT_SECRET=...
REDDIT_USER_AGENT=forge-scout/1.0
# Optional: Serper API for Google trends
SERPER_API_KEY=...

# ── IMAGE GENERATION (thumbnails) ────────────────────────
GOOGLE_AI_API_KEY=...

# ── REDIS (job state) ────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── WHISPER (captions) ───────────────────────────────────
WHISPER_MODEL=base               # tiny | base | small | medium | large
# Set to openai to use OpenAI Whisper API instead of local
WHISPER_PROVIDER=local

# ── OPENAI (optional — Whisper API fallback) ─────────────
OPENAI_API_KEY=...
